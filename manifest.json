{
  "manifest_version": 2,
  "version": "0.1.0",
  "name": "Humble Apollo",
  "description": "A high-contrast dark Firefox theme based on the Gruvbox dark hard palette.",
  "browser_specific_settings": {
    "gecko": {
      "id": "humble-apollo@d0n9x1n",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "theme": {
    "colors": {
      "frame": "#1d2021",
      "frame_inactive": "#1d2021",

      "tab_background_text": "#fdf4c1",
      "tab_selected": "#282828",
      "tab_text": "#fabd2f",
      "tab_line": "#1d2021",
      "tab_loading": "#fabd2f",
      "tab_background_separator": "#000000",

      "toolbar": "#1d2021",
      "toolbar_text": "#fdf4c1",
      "toolbar_field": "#000000",
      "toolbar_field_text": "#fdf4c1",
      "toolbar_field_focus": "#000000",
      "toolbar_field_text_focus": "#fdf4c1",
      "toolbar_field_border_focus": "#fabd2f",
      "toolbar_field_separator": "#000000",
      "toolbar_vertical_separator": "#282828",

      "icons": "#fdf4c1",
      "icons_attention": "#fabd2f",

      "ntp_background": "#1d2021",
      "ntp_text": "#fdf4c1",

      "popup": "#3c3836",
      "popup_border": "#1d2021",
      "popup_highlight": "#7c6f64",
      "popup_highlight_text": "#fdf4c1",
      "popup_text": "#fdf4c1",

      "sidebar": "#1d2021",
      "sidebar_border": "#3c3836",
      "sidebar_highlight": "#7c6f64",
      "sidebar_highlight_text": "#fdf4c1",
      "sidebar_text": "#fdf4c1",

      "bookmark_text": "#fdf4c1"
    }
  }
}
